# ─── MNQ AI Trader — Environment Template ─────────────────────
# Copy to .env and fill in your values
# NEVER commit .env to git

# ─── REQUIRED ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── PATHS ────────────────────────────────────────────────────
BASE_DIR=C:\trading\mnq-ai-trader

# ─── IBKR ─────────────────────────────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ─── ACCOUNT ──────────────────────────────────────────────────
ACCOUNT_SIZE=50000
MAX_DAILY_LOSS_PCT=0.01

# ─── CONTRACT (update when MNQ rolls quarterly) ───────────────
CONTRACT_EXPIRY=20260618
CONTRACT_CONID=770561201

# ─── LIVE DATA (requires CME subscription in IBKR) ────────────
LIVE_DATA_ACTIVE=true

# ─── MODELS ───────────────────────────────────────────────────
CLAUDE_ENTRY_MODEL=claude-opus-4-7
CLAUDE_POSITION_MODEL=claude-sonnet-4-6
CLAUDE_STRUCTURE_MODEL=claude-sonnet-4-6
CLAUDE_USE_CACHING=true

# ─── RISK ─────────────────────────────────────────────────────
MAX_SESSION_R_LOSS=3.0
MAX_CONTRACTS=1

# ─── RECORDING ────────────────────────────────────────────────
RECORDING_ENABLED=true

# ─── NIGHT OWL — 24/7 unrestricted scanning ──────────────────
# When true: the bot stays connected through weekends/holidays,
# get_session_state forces PRIME_WINDOW outside the 08:30-09:30 ET
# pre-market analysis window, _wait_for_market_hours short-circuits,
# and DEAD_ZONE / CLOSING gates are bypassed. Pre-market still fires
# at 08:30, EOD still fires at EOD_SCHEDULE_TIME. Risk caps unchanged.
NIGHT_OWL=false

# ─── V4.0 — THESIS PROBABILITY GATE ──────────────────────────
# Claude outputs 0-100 thesis probability. Entries blocked below threshold.
# 0 = disabled. 70 = recommended (fairly confident before entering).
MIN_THESIS_PROBABILITY=70

# ─── VERSION (managed automatically by version_manager.py) ───
BOT_VERSION=4.1.0

# ═══════════════════════════════════════════════════════════
# V4.1 FEATURE FLAGS
# Toggle on/off for ablation testing and live trading.
# All default to true (fully featured). Set to false to disable.
# ═══════════════════════════════════════════════════════════

# Strategy / Bias
FEATURE_ORB_BIAS=true        # OR direction as starting bias
FEATURE_BIDIRECTIONAL=true   # Allow shorts on bull days
FEATURE_BIAS_DECAY=true      # Bias decays to NEUTRAL after 90min

# Predictive Signals
FEATURE_OFI=true             # Order Flow Imbalance score
FEATURE_DOM_ADVANCED=true    # Iceberg/spoof/sweep/cluster detection
FEATURE_MTF_SCORE=true       # Numeric MTF alignment score
FEATURE_DELTA_LIVE=true      # True bid/ask delta classification

# Entry Gates
FEATURE_THESIS_GATE=true     # Thesis probability threshold gate
FEATURE_R_BUDGET=true        # Session R-loss cap
FEATURE_NEWS_GATE=true       # Block entries near high-impact news
FEATURE_DEAD_ZONE=true       # Reduce entries 11am-1:30pm ET

# Position Management
FEATURE_DUAL_TRAIL=true      # Claude trail anchors auto-trail
FEATURE_EARLY_EXIT=true      # Allow Claude to close before stop

# Learning
FEATURE_LEARNING_EOD=true    # Run ablation + learning at EOD
FEATURE_LEARNING_INJECT=true # Inject learnings into pre-market

# ─── COMMISSIONS ───────────────────────────────────────────
# false = paper trading (no fee drag, $0 commissions)
# true  = simulate realistic IBKR fees (~$0.85/side for MNQ)
#         Enables commission drag analysis in EOD learning session.
#         Set true before live money to see realistic net P&L.
SIMULATE_COMMISSIONS=false
COMMISSION_PER_SIDE_USD=0.85

# ─── PUSH NOTIFICATIONS (ntfy.sh — free, no API key) ──────
# 1. Install ntfy app on iPhone/Android from App Store / Play Store
# 2. Subscribe to your unique topic in the app
# 3. Set NTFY_TOPIC below — make it unique & hard to guess
#    (anyone who knows your topic can see your notifications)
# Leave NTFY_TOPIC blank to disable notifications.
NTFY_TOPIC=
NTFY_URL=https://ntfy.sh
NOTIFY_ENABLED=true
